{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist/scraper",
    "noEmit": false
  },
  "include": [
    "scrapers/**/*",
    "lib/email.ts",
    "lib/supabase/**/*",
    "types/**/*"
  ],
  "exclude": [
    "node_modules",
    "app",
    ".next",
    "lib/email-app.ts"
  ]
}
