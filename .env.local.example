# ─────────────────────────────────────────────────────────
# ClearedNo — Environment Variables
# Copy this file to .env.local and fill in every value.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────

# Supabase
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Stripe Customer Portal URL
# Stripe → Settings → Billing → Customer portal → copy the portal link
# Looks like: https://billing.stripe.com/p/login/...
# No NEXT_PUBLIC_ prefix — kept server-side only, never in the client bundle.
STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/...

# Resend
# resend.com → API Keys
RESEND_API_KEY=re_...

# Your deployed domain (no trailing slash)
NEXT_PUBLIC_URL=https://www.clearedno.com

# Email sender identity (must be a verified domain in Resend)
FROM_EMAIL=alerts@clearedno.com
FROM_NAME=ClearedNo

# Outreach agent (optional)
# Used by outreach/email-writer.ts to generate cold emails with Claude
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps — used by outreach/lead-finder.ts
GOOGLE_MAPS_API_KEY=AIza...
