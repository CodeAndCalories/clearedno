# ─────────────────────────────────────────────────────────
# ClearedNo — Environment Variables
# Copy this file to .env.local and fill in every value.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────

# Supabase
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# Founding member: uses STRIPE_PRICE_ID + FOUNDING49 coupon (no separate price needed)

# Resend
# resend.com → API Keys
RESEND_API_KEY=re_...

# Your deployed domain (no trailing slash)
NEXT_PUBLIC_URL=https://www.clearedno.com

# Email sender identity (domain must be verified in Resend)
FROM_EMAIL=alerts@clearedno.com
FROM_NAME=ClearedNo

# Admin alert recipient
# The scraper sends an email here when a city portal fails 3+ times in a row.
# Can be the same as FROM_EMAIL or a separate ops inbox.
ADMIN_EMAIL=you@yourcompany.com

# Dry-run mode — applies to both the scraper and the outreach agent
# Set to true for testing - skips DB writes and email sends
# Default: false
DRY_RUN=false

# Web Push Notifications (optional)
# Generate keys with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_KEY is safe to expose to the browser (used in service worker).
# VAPID_PRIVATE_KEY must stay server-side only — never expose it.
NEXT_PUBLIC_VAPID_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:support@clearedno.com

# Outreach agent (optional)
# Used by outreach/email-writer.ts to generate cold emails with Claude
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps — used by outreach/lead-finder.ts
GOOGLE_MAPS_API_KEY=AIza...

# Gmail API — used by outreach/gmail-sender.ts to send cold emails
# 1. Google Cloud Console → APIs & Services → Enable "Gmail API"
# 2. Credentials → Create OAuth client ID (Desktop app) → Download JSON
# 3. Save as outreach/credentials.json
# 4. Run: npx ts-node --project tsconfig.scripts.json outreach/gmail-auth.ts
#    to generate outreach/token.json (one-time browser auth flow)
# Both files are .gitignored — never commit them.
GMAIL_CREDENTIALS_PATH=./outreach/credentials.json
GMAIL_TOKEN_PATH=./outreach/token.json

# Gmail App Password (for GitHub Actions / automated sending — no OAuth needed)
# Get from: myaccount.google.com/apppasswords (requires 2-Step Verification)
# When set, overrides OAuth — use this in production/CI
GMAIL_APP_PASSWORD=
